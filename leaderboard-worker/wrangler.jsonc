{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "space-salvager-leaderboard",
  "main": "src/index.js",
  "compatibility_date": "2026-07-21",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "LEADERBOARD",
        "class_name": "LeaderboardStore"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["LeaderboardStore"]
    }
  ]
}
